# Client ID de Google AdSense (formato: ca-pub-XXXXXXXXXXXXXXXX).
# Déjalo vacío hasta tener la cuenta de AdSense aprobada: si está vacío,
# el sitio no inyecta el script de AdSense ni renderiza los <AdSlot />.
PUBLIC_ADSENSE_CLIENT_ID=

# ID de medición de Google Analytics (formato: G-XXXXXXXXXX).
# Déjalo vacío para no cargar el gtag. Si está vacío, el sitio no
# inyecta ningún script de Analytics.
PUBLIC_GA_MEASUREMENT_ID=
