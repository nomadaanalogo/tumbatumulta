---
import BaseLayout from './BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import AnalyzeCTA from '../components/AnalyzeCTA.astro';
import Icon from '../components/Icon.astro';
import { SITE_NAME, CATEGORY_ICONS, AD_SLOTS } from '../consts';

interface Props {
  title: string;
  description: string;
  category: string;
  updatedDate: Date;
}

const { title, description, category, updatedDate } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: updatedDate.toISOString(),
  dateModified: updatedDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: SITE_NAME,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE_NAME,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL,
  },
  inLanguage: 'es-CO',
};

const formattedDate = updatedDate.toLocaleDateString('es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <nav class="mb-4 text-sm text-slate-500 dark:text-slate-400">
      <a href="/" class="hover:text-blue-700 dark:hover:text-blue-400">Inicio</a>
      <span class="mx-1">/</span>
      <a href="/blog/" class="hover:text-blue-700 dark:hover:text-blue-400">Guía</a>
      <span class="mx-1">/</span>
      <span class="text-slate-700 dark:text-slate-300">{title}</span>
    </nav>

    <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800 dark:bg-blue-900/50 dark:text-blue-300">
      <Icon name={CATEGORY_ICONS[category as keyof typeof CATEGORY_ICONS]} size={14} strokeWidth={2} />
      {category}
    </span>

    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
      {title}
    </h1>

    <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">
      Actualizado el {formattedDate}
    </p>

    <AdSlot adSlot={AD_SLOTS.articleTop} class="my-8" />

    <div class="prose prose-slate mt-4 max-w-none dark:prose-invert prose-a:text-blue-700 dark:prose-a:text-blue-400">
      <slot />

      <AnalyzeCTA />
    </div>

    <AdSlot adSlot={AD_SLOTS.articleBottom} class="my-8" />
  </article>
</BaseLayout>
