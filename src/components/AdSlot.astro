---
interface Props {
  adSlot: string;
  format?: string;
  class?: string;
}

const { adSlot, format = 'auto', class: className = '' } = Astro.props;
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
const hasRealSlot = Boolean(adSlot) && !adSlot.startsWith('REPLACE_WITH');
---

{
  client && hasRealSlot && (
    <div class={`ad-slot my-8 flex justify-center ${className}`}>
      <ins
        class="adsbygoogle"
        style="display:block; width:100%;"
        data-ad-client={client}
        data-ad-slot={adSlot}
        data-ad-format={format}
        data-full-width-responsive="true"
      />
      <script is:inline>
        (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </div>
  )
}
