---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div
  class={`rounded-3xl border border-blue-100 bg-gradient-to-br from-blue-50 to-white p-6 dark:border-slate-700 dark:from-slate-900 dark:to-slate-900 ${className}`}
>
  <svg
    viewBox="0 0 400 300"
    class="h-auto w-full"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Ilustración de un carro estacionado junto a un comparendo de tránsito siendo revisado con una lupa"
  >
    <!-- decorative dots -->
    <circle cx="40" cy="60" r="5" fill="#93c5fd" opacity="0.6" />
    <circle cx="365" cy="245" r="6" fill="#fcd34d" opacity="0.6" />
    <circle cx="355" cy="55" r="4" fill="#93c5fd" opacity="0.5" />

    <!-- road -->
    <line x1="15" y1="272" x2="385" y2="272" stroke="#cbd5e1" stroke-width="3" stroke-dasharray="12 10" />
    <ellipse cx="120" cy="270" rx="95" ry="12" fill="#0f172a" opacity="0.08" />

    <!-- car -->
    <g>
      <path
        d="M45 245 Q40 245 40 233 L40 222 Q40 210 52 210 L70 210 L92 172 Q100 162 116 162 L152 162 Q166 162 174 174 L192 210 L200 210 Q212 210 212 222 L212 233 Q212 245 200 245 Z"
        fill="#2563eb"
      />
      <path d="M100 205 L114 178 Q118 172 126 172 L146 172 L162 205 Z" fill="#bfdbfe" opacity="0.9" />
      <line x1="132" y1="172" x2="128" y2="205" stroke="#2563eb" stroke-width="2.5" />
      <circle cx="75" cy="248" r="19" fill="#0f172a" />
      <circle cx="75" cy="248" r="7" fill="#cbd5e1" />
      <circle cx="178" cy="248" r="19" fill="#0f172a" />
      <circle cx="178" cy="248" r="7" fill="#cbd5e1" />
      <circle cx="55" cy="222" r="4" fill="#fde68a" />
    </g>

    <!-- ticket card -->
    <g transform="rotate(6 300 150)">
      <rect x="228" y="66" width="144" height="176" rx="14" fill="#ffffff" stroke="#e2e8f0" stroke-width="2" />
      <path d="M228 80a14 14 0 0 1 14-14h116a14 14 0 0 1 14 14v14H228z" fill="#f59e0b" />
      <rect x="244" y="108" width="96" height="11" rx="5.5" fill="#cbd5e1" />
      <rect x="244" y="129" width="112" height="8" rx="4" fill="#e2e8f0" />
      <rect x="244" y="145" width="76" height="8" rx="4" fill="#e2e8f0" />
      <rect x="244" y="161" width="104" height="8" rx="4" fill="#e2e8f0" />
      <circle cx="266" cy="205" r="17" fill="#eff6ff" stroke="#2563eb" stroke-width="2" />
      <path d="M266 196v9l6 4" stroke="#2563eb" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
    </g>

    <!-- magnifying glass with checkmark -->
    <g transform="translate(232 196) rotate(-12)">
      <circle cx="0" cy="0" r="27" fill="#ffffff" stroke="#1d4ed8" stroke-width="6" />
      <line x1="19" y1="19" x2="42" y2="42" stroke="#1d4ed8" stroke-width="8" stroke-linecap="round" />
      <polyline
        points="-11,0 -3,9 13,-9"
        stroke="#16a34a"
        stroke-width="4.5"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </g>
  </svg>
</div>
