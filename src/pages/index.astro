---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon, { type IconName } from '../components/Icon.astro';
import HeroIllustration from '../components/illustrations/HeroIllustration.astro';
import { SITE_NAME } from '../consts';

const featured: { href: string; title: string; description: string; icon: IconName }[] = [
  {
    href: '/blog/multas-de-transito-en-colombia-guia-completa/',
    title: 'Multas de tránsito en Colombia: guía completa',
    description: 'El mapa general: qué es una multa, cómo consultarla, y cuándo la ley te respalda para no pagarla.',
    icon: 'document',
  },
  {
    href: '/blog/no-pagues-tu-multa-de-transito/',
    title: 'No pagues tu multa de tránsito sin hacer esto primero',
    description: 'Los 5 escenarios reales en los que la ley colombiana dice que no estás obligado a pagar.',
    icon: 'check-circle',
  },
  {
    href: '/blog/caso-tumbar-multa-transito-mas-de-6-anos/',
    title: 'Caso ilustrativo: así se tumba una multa de más de 6 años',
    description: 'Derecho de petición, un segundo intento, tutela, y por qué al final se cayó el cobro.',
    icon: 'sparkles',
  },
  {
    href: '/blog/caducidad-vs-prescripcion-multas-transito/',
    title: 'Caducidad vs. prescripción: la diferencia que más dinero te puede ahorrar',
    description:
      'Son dos figuras distintas y casi nadie las explica bien. Aquí sabrás cuál aplica a tu caso.',
    icon: 'clock',
  },
  {
    href: '/blog/que-es-el-cobro-coactivo-en-colombia/',
    title: '¿Qué es el cobro coactivo en Colombia?',
    description: 'Cómo funciona el proceso con el que el Estado cobra sin pasar por un juez, y tus opciones.',
    icon: 'lock',
  },
  {
    href: '/blog/simit-vs-runt-diferencias/',
    title: 'SIMIT vs. RUNT: qué son y cómo se conectan',
    description: 'Por qué una multa sin pagar en el SIMIT puede bloquearte trámites en el RUNT.',
    icon: 'search',
  },
  {
    href: '/blog/tipos-de-multas-de-transito-en-colombia/',
    title: 'Tipos de multas de tránsito en Colombia',
    description: 'Velocidad, semáforo, parqueo, documentos, alcoholemia: qué tan defendible es cada una.',
    icon: 'camera',
  },
];

const steps: { icon: IconName; title: string; description: string }[] = [
  {
    icon: 'search',
    title: '1. Entiende tu caso',
    description:
      'Lee los artículos relevantes a tu situación: fecha del comparendo, tipo de infracción, si te notificaron o no.',
  },
  {
    icon: 'sparkles',
    title: '2. Analiza tu multa con IA',
    description:
      'Usa nuestro prompt gratuito en ChatGPT, Gemini o Claude para obtener una recomendación puntual sobre tu caso.',
  },
  {
    icon: 'check-circle',
    title: '3. Actúa a tiempo',
    description:
      'Presenta un derecho de petición, una excepción o un recurso dentro de los plazos legales — perderlos es lo que más le cuesta a la gente.',
  },
];

const title = SITE_NAME;
const description =
  'Antes de pagar tu multa de tránsito en Colombia, entiende tus opciones: prescripción, caducidad, fotomultas mal notificadas y derecho de petición. Guía gratuita y clara.';
---

<BaseLayout title={title} description={description}>
  <section class="mx-auto max-w-6xl px-4 pb-16 pt-14 sm:px-6 sm:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="inline-flex items-center gap-1.5 text-sm font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-400">
          <Icon name="shield-check" size={16} strokeWidth={2} />
          Guía gratuita sobre multas de tránsito en Colombia
        </p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-5xl">
          Antes de pagar tu multa, entiende tus opciones.
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          Muchas multas de tránsito en Colombia tienen defectos que las hacen impugnables: notificaciones
          tardías, fotomultas sin señalización o sin calibración vigente, comparendos ya prescritos o caducados.
          Te explicamos, en lenguaje claro, qué dice realmente la ley antes de que saques la billetera.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/analiza-tu-multa/"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-blue-600 px-6 py-3 text-center text-base font-semibold text-white transition-colors hover:bg-blue-700"
          >
            <Icon name="sparkles" size={18} strokeWidth={2} />
            Analiza tu multa gratis con IA
          </a>
          <a
            href="/blog/"
            class="inline-flex items-center justify-center gap-2 rounded-md border border-slate-300 px-6 py-3 text-center text-base font-semibold text-slate-700 transition-colors hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900"
          >
            <Icon name="document" size={18} strokeWidth={2} />
            Ver toda la guía
          </a>
        </div>
      </div>

      <HeroIllustration class="w-full" />
    </div>

    <div class="mt-10 flex max-w-3xl gap-3 rounded-xl border border-amber-300 bg-amber-50 p-5 dark:border-amber-800 dark:bg-amber-950/40">
      <Icon name="alert-triangle" size={22} class="mt-0.5 shrink-0 text-amber-600 dark:text-amber-400" />
      <p class="text-sm leading-relaxed text-amber-900 dark:text-amber-200">
        <strong>Una excepción honesta:</strong> si tu comparendo es por embriaguez o niveles de alcohol/sustancias
        psicoactivas (alcoholemia), esta guía no aplica igual. Ese tipo de infracción tiene una prueba técnica
        directa (la prueba de alcoholemia) y consecuencias que van más allá de una multa administrativa —
        no es un caso donde recomendemos buscar defectos de forma para no pagar. Si es tu situación, consulta
        directamente con un abogado penalista/de tránsito.
      </p>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Los artículos más buscados</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        {
          featured.map((post) => (
            <a
              href={post.href}
              class="flex gap-4 rounded-xl border border-slate-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-slate-800 dark:bg-slate-950"
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/50 dark:text-blue-300">
                <Icon name={post.icon} size={20} strokeWidth={1.8} />
              </span>
              <div>
                <h3 class="font-semibold text-slate-900 dark:text-white">{post.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{post.description}</p>
              </div>
            </a>
          ))
        }
      </div>
      <div class="mt-8">
        <a
          href="/blog/"
          class="inline-flex items-center gap-1 text-sm font-semibold text-blue-700 hover:underline dark:text-blue-400"
        >
          Ver todos los artículos de la guía
          <Icon name="arrow-right" size={16} strokeWidth={2} />
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-3">
      {
        steps.map((step) => (
          <div>
            <span class="flex h-11 w-11 items-center justify-center rounded-full bg-blue-600 text-white">
              <Icon name={step.icon} size={20} strokeWidth={1.8} />
            </span>
            <h3 class="mt-4 font-semibold text-slate-900 dark:text-white">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{step.description}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-12 rounded-xl border border-blue-200 bg-blue-50 p-8 text-center dark:border-blue-900 dark:bg-blue-950/40">
      <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-blue-600 text-white">
        <Icon name="megaphone" size={22} strokeWidth={1.8} />
      </span>
      <h2 class="mt-4 text-xl font-bold text-slate-900 dark:text-white">¿Ya tienes el pantallazo del SIMIT a la mano?</h2>
      <p class="mx-auto mt-2 max-w-xl text-sm leading-relaxed text-slate-700 dark:text-slate-300">
        En dos minutos puedes tener una primera orientación gratuita sobre qué hacer con tu multa.
      </p>
      <a
        href="/analiza-tu-multa/"
        class="mt-5 inline-flex items-center gap-2 rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-blue-700"
      >
        Analiza tu multa ahora
        <Icon name="arrow-right" size={16} strokeWidth={2} />
      </a>
    </div>
  </section>
</BaseLayout>
