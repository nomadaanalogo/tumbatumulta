---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { CATEGORIES, CATEGORY_ICONS } from '../../consts';

const allPosts = await getCollection('blog');
allPosts.sort((a, b) => a.data.order - b.data.order);

const grouped = CATEGORIES.map((category) => ({
  category,
  posts: allPosts.filter((post) => post.data.category === category),
})).filter((group) => group.posts.length > 0);

const title = 'Guía de multas de tránsito en Colombia';
const description =
  'Todos los artículos de TumbaTuMulta sobre prescripción, caducidad, fotomultas, SIMIT, RUNT, derecho de petición, tutela y cobro coactivo, explicados en lenguaje claro.';
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
      Guía completa de multas de tránsito en Colombia
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-slate-600 dark:text-slate-300">
      Antes de pagar, entiende qué dice realmente la ley. Estos artículos explican, con lenguaje sencillo,
      los mismos conceptos que usaría un abogado de tránsito para evaluar tu comparendo.
    </p>

    <div class="mt-12 space-y-14">
      {
        grouped.map((group) => (
          <section>
            <h2 class="flex items-center gap-2 border-b border-slate-200 pb-2 text-xl font-bold text-slate-900 dark:border-slate-800 dark:text-white">
              <Icon name={CATEGORY_ICONS[group.category]} size={20} strokeWidth={1.8} class="text-blue-700 dark:text-blue-400" />
              {group.category}
            </h2>
            <div class="mt-6 grid gap-6 sm:grid-cols-2">
              {group.posts.map((post) => (
                <a
                  href={`/blog/${post.id}/`}
                  class="block rounded-xl border border-slate-200 p-5 transition-shadow hover:shadow-md dark:border-slate-800"
                >
                  <h3 class="font-semibold text-slate-900 dark:text-white">{post.data.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                    {post.data.description}
                  </p>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>
